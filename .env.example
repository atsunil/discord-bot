# Discord Bot Token (from Discord Developer Portal)
DISCORD_BOT_TOKEN=your-discord-token-here

# NVIDIA NIM API Key (from build.nvidia.com)
NVIDIA_API_KEY=your-nvidia-api-key-here

# Comma-separated list of super users (names or IDs)
SUPER_USERS=your-user-id-or-name-here

# Supabase (from supabase.com — Project Settings > API)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-public-key-here
