# Discord
DISCORD_BOT_TOKEN=your_discord_bot_token_here
DISCORD_CLIENT_ID=your_discord_app_client_id
DISCORD_CLIENT_SECRET=your_discord_oauth_secret

# NVIDIA NIM
NVIDIA_API_KEY=your_nvidia_nim_api_key_here
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
NIM_CHAT_MODEL=nvidia/llama-3.1-nemotron-ultra-253b-v1
NIM_FALLBACK_MODEL=meta/llama-3.1-70b-instruct
NIM_IMAGE_URL=https://ai.api.nvidia.com/v1/genai/stabilityai/stable-diffusion-xl

# MongoDB Atlas
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/moloj

# Razorpay
RAZORPAY_KEY_ID=rzp_live_xxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# App
SECRET_KEY=any_random_32_char_string_for_sessions
DASHBOARD_URL=https://moloj-dashboard.onrender.com
PORT=8080
HEALTH_HOST=0.0.0.0
LOG_FILE=moloj.log

# Bot settings
SUPER_USERS=your_discord_user_id_here
ALLOW_UNSAFE_TOOLS=false
LAVALINK_URI=https://lavalink.devamop.in
LAVALINK_PASSWORD=devamop.in
